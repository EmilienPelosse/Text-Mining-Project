        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a262" TIME_SLOT_REF1="ts517" TIME_SLOT_REF2="ts518">
                <ANNOTATION_VALUE>that I do not do away</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a263" TIME_SLOT_REF1="ts519" TIME_SLOT_REF2="ts520">

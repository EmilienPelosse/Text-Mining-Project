                <ANNOTATION_VALUE>responsive audience</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a178" TIME_SLOT_REF1="ts349" TIME_SLOT_REF2="ts350">
                <ANNOTATION_VALUE>unfortunately such a history was stained</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a179" TIME_SLOT_REF1="ts351" TIME_SLOT_REF2="ts352">
                <ANNOTATION_VALUE>with imposing stains</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a180" TIME_SLOT_REF1="ts353" TIME_SLOT_REF2="ts354">
                <ANNOTATION_VALUE>resulting from the gulf</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a181" TIME_SLOT_REF1="ts355" TIME_SLOT_REF2="ts356">
                <ANNOTATION_VALUE>between the literary critics</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a182" TIME_SLOT_REF1="ts357" TIME_SLOT_REF2="ts358">
                <ANNOTATION_VALUE>and the linguists</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a183" TIME_SLOT_REF1="ts359" TIME_SLOT_REF2="ts360">
                <ANNOTATION_VALUE>who were then applying the resources of language in assessment</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a184" TIME_SLOT_REF1="ts361" TIME_SLOT_REF2="ts362">
                <ANNOTATION_VALUE>and appreciation of literature</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a185" TIME_SLOT_REF1="ts363" TIME_SLOT_REF2="ts364">
                <ANNOTATION_VALUE>what was actually disturbing</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a186" TIME_SLOT_REF1="ts365" TIME_SLOT_REF2="ts366">
                <ANNOTATION_VALUE>was the</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a187" TIME_SLOT_REF1="ts367" TIME_SLOT_REF2="ts368">
                <ANNOTATION_VALUE>extremity of emotions that characterise</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a188" TIME_SLOT_REF1="ts369" TIME_SLOT_REF2="ts370">
                <ANNOTATION_VALUE>apparently polar ends at the time</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a189" TIME_SLOT_REF1="ts371" TIME_SLOT_REF2="ts372">
                <ANNOTATION_VALUE>or how else could one describe</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a190" TIME_SLOT_REF1="ts373" TIME_SLOT_REF2="ts374">
                <ANNOTATION_VALUE>Vendler's</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a191" TIME_SLOT_REF1="ts375" TIME_SLOT_REF2="ts376">
                <ANNOTATION_VALUE>aggressive and hostile reaction</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a192" TIME_SLOT_REF1="ts377" TIME_SLOT_REF2="ts378">
                <ANNOTATION_VALUE>to Sinclair's taking a poem to pieces</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a193" TIME_SLOT_REF1="ts379" TIME_SLOT_REF2="ts380">
                <ANNOTATION_VALUE>even when Professor Sinclair hinted that what</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a194" TIME_SLOT_REF1="ts381" TIME_SLOT_REF2="ts382">
                <ANNOTATION_VALUE>I've done in decency</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a452" TIME_SLOT_REF1="ts383" TIME_SLOT_REF2="ts384">
                <ANNOTATION_VALUE>was to show how some aspects of the meaning of</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a195" TIME_SLOT_REF1="ts385" TIME_SLOT_REF2="ts386">
                <ANNOTATION_VALUE>the poem could be described quite independently of evaluation</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a196" TIME_SLOT_REF1="ts387" TIME_SLOT_REF2="ts388">
                <ANNOTATION_VALUE>Vendler</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a197" TIME_SLOT_REF1="ts389" TIME_SLOT_REF2="ts390">
                <ANNOTATION_VALUE>could not accommodate</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a198" TIME_SLOT_REF1="ts391" TIME_SLOT_REF2="ts392">
                <ANNOTATION_VALUE>and I quote</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a199" TIME_SLOT_REF1="ts393" TIME_SLOT_REF2="ts394">
                <ANNOTATION_VALUE>the unreasonable and barbaric collection of symbols and words</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a200" TIME_SLOT_REF1="ts395" TIME_SLOT_REF2="ts396">
                <ANNOTATION_VALUE>which characterised the</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a201" TIME_SLOT_REF1="ts397" TIME_SLOT_REF2="ts398">
                <ANNOTATION_VALUE>triviality of tediousness of the jargons of Sinclair's linguistic description</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a202" TIME_SLOT_REF1="ts399" TIME_SLOT_REF2="ts400">
                <ANNOTATION_VALUE>other instances of such negative reactions abound</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a203" TIME_SLOT_REF1="ts401" TIME_SLOT_REF2="ts402">
                <ANNOTATION_VALUE>but what actually drew the attention of the intellectual world at the time was a crisis</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a204" TIME_SLOT_REF1="ts403" TIME_SLOT_REF2="ts404">
                <ANNOTATION_VALUE>precipitated in the world's first department of English in the University of Cambridge</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a205" TIME_SLOT_REF1="ts405" TIME_SLOT_REF2="ts406">
                <ANNOTATION_VALUE>with the forced retrenchment</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a206" TIME_SLOT_REF1="ts407" TIME_SLOT_REF2="ts408">
                <ANNOTATION_VALUE>of the only don with structuralist</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a207" TIME_SLOT_REF1="ts409" TIME_SLOT_REF2="ts410">
                <ANNOTATION_VALUE>inclination</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a208" TIME_SLOT_REF1="ts411" TIME_SLOT_REF2="ts412">
                <ANNOTATION_VALUE>as master-minded</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a209" TIME_SLOT_REF1="ts413" TIME_SLOT_REF2="ts414">
                <ANNOTATION_VALUE>as master-minded by the literary critical conservatives of the time</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a210" TIME_SLOT_REF1="ts415" TIME_SLOT_REF2="ts416">
                <ANNOTATION_VALUE>it appears to Humes</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a211" TIME_SLOT_REF1="ts417" TIME_SLOT_REF2="ts418">
                <ANNOTATION_VALUE>then that literary criticism and linguistics would never be at</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a212" TIME_SLOT_REF1="ts419" TIME_SLOT_REF2="ts420">
                <ANNOTATION_VALUE>any united field</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>

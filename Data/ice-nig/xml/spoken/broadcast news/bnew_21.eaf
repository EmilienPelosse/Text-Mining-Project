            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a218" TIME_SLOT_REF1="ts647" TIME_SLOT_REF2="ts650">
                <ANNOTATION_VALUE>he assured that the buildings will be ready by September this year</ANNOTATION_VALUE>

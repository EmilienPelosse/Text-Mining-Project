        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a94" TIME_SLOT_REF1="ts321" TIME_SLOT_REF2="ts327">
                <ANNOTATION_VALUE>next week is another date and it will be the last edition of This Week In History</ANNOTATION_VALUE>

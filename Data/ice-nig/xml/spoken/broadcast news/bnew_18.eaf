        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a205" TIME_SLOT_REF1="ts699" TIME_SLOT_REF2="ts702">
                <ANNOTATION_VALUE>in spite of their busy schedules they stand in the face of sometimes unruly road users</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a207" TIME_SLOT_REF1="ts703" TIME_SLOT_REF2="ts706">

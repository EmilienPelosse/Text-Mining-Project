            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a512" TIME_SLOT_REF1="ts1613" TIME_SLOT_REF2="ts1618">
                <ANNOTATION_VALUE>we cannot provide employment for a hundred and fifty million people</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a513" TIME_SLOT_REF1="ts1619" TIME_SLOT_REF2="ts1620">
                <ANNOTATION_VALUE>I wonder what we are going to do </ANNOTATION_VALUE>

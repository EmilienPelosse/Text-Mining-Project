        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a194" TIME_SLOT_REF1="ts515" TIME_SLOT_REF2="ts516">
                <ANNOTATION_VALUE>they try to manage the sanitary condition of the market</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a195" TIME_SLOT_REF1="ts517" TIME_SLOT_REF2="ts518">

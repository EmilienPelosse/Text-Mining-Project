        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a148" TIME_SLOT_REF1="ts445" TIME_SLOT_REF2="ts448">
                <ANNOTATION_VALUE>the situation at Ilala Obalogun village in Ife east local government</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a149" TIME_SLOT_REF1="ts449" TIME_SLOT_REF2="ts450">
                <ANNOTATION_VALUE>it's six kilometres from Ile-Ife township</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a150" TIME_SLOT_REF1="ts451" TIME_SLOT_REF2="ts452">
                <ANNOTATION_VALUE>following the burning of their cocoa farms</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a151" TIME_SLOT_REF1="ts453" TIME_SLOT_REF2="ts456">

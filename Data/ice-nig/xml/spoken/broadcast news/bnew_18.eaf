        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a211" TIME_SLOT_REF1="ts723" TIME_SLOT_REF2="ts726">
                <ANNOTATION_VALUE>FCT sector commander Nsibong Akpabio</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a212" TIME_SLOT_REF1="ts727" TIME_SLOT_REF2="ts730">
                <ANNOTATION_VALUE>says it is no accident that they were chosen</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a213" TIME_SLOT_REF1="ts731" TIME_SLOT_REF2="ts733">
                <ANNOTATION_VALUE>various speakers at the inauguration</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a214" TIME_SLOT_REF1="ts735" TIME_SLOT_REF2="ts740">
                <ANNOTATION_VALUE>continuously echoed the need to ensure safety and commitment to duty</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a215" TIME_SLOT_REF1="ts741" TIME_SLOT_REF2="ts746">
                <ANNOTATION_VALUE>with the NNPC aiming for a world-class status</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a216" TIME_SLOT_REF1="ts747" TIME_SLOT_REF2="ts750">
                <ANNOTATION_VALUE>General Manager Environment and Safety Rabiu Suleiman</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a217" TIME_SLOT_REF1="ts751" TIME_SLOT_REF2="ts756">
                <ANNOTATION_VALUE>says the inductees carry added responsibilities</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a218" TIME_SLOT_REF1="ts757" TIME_SLOT_REF2="ts758">
                <ANNOTATION_VALUE>there are forty three special marshal units currently complementing the duties of  the federal road safety commission in the FCT</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a219" TIME_SLOT_REF1="ts759" TIME_SLOT_REF2="ts764">
                <ANNOTATION_VALUE>those at the events of the latest addition of special marshals</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a220" TIME_SLOT_REF1="ts765" TIME_SLOT_REF2="ts770">
                <ANNOTATION_VALUE>will assist the FRC in maintaining compliance</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a221" TIME_SLOT_REF1="ts771" TIME_SLOT_REF2="ts773">
                <ANNOTATION_VALUE>with traffic rules and quick response to emergencies</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a222" TIME_SLOT_REF1="ts775" TIME_SLOT_REF2="ts778">
                <ANNOTATION_VALUE>on the highways</ANNOTATION_VALUE>

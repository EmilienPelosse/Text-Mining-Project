        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a138" TIME_SLOT_REF1="ts451" TIME_SLOT_REF2="ts455">
                <ANNOTATION_VALUE>paid tribute to Nigerian woman many who have not been publically acknowledged</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a139" TIME_SLOT_REF1="ts457" TIME_SLOT_REF2="ts458">
                <ANNOTATION_VALUE>for what she described as their resilience in a male-dominated society</ANNOTATION_VALUE>

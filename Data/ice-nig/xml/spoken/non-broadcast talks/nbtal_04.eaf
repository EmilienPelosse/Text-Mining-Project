        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a142" TIME_SLOT_REF1="ts275" TIME_SLOT_REF2="ts276">
                <ANNOTATION_VALUE>and that's why Leech believes strongly that</ANNOTATION_VALUE>

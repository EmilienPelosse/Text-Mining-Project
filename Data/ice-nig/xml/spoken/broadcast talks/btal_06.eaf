        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a73" TIME_SLOT_REF1="ts281" TIME_SLOT_REF2="ts284">
                <ANNOTATION_VALUE>and the happiness of believers</ANNOTATION_VALUE>

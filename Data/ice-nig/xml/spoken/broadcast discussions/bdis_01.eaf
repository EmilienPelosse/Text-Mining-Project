        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a359" TIME_SLOT_REF1="ts1155" TIME_SLOT_REF2="ts1156">
                <ANNOTATION_VALUE>that quality of competitive revaluation of currencies</ANNOTATION_VALUE>

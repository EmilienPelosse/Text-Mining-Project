        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a51" TIME_SLOT_REF1="ts125" TIME_SLOT_REF2="ts128">
                <ANNOTATION_VALUE>in line with the federal government's adherence to due process</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>

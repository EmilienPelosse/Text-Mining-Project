    <TIER ANNOTATOR="ug/lc/pi DONE DONE DONE rf/pi/ug DONE DONE DONE" DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="default-lt" PARTICIPANT="2007-?-?;Delta state;m;?;?" TIER_ID="Transcription 1">
        <ANNOTATION>

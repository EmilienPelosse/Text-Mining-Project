        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a252" TIME_SLOT_REF1="ts649" TIME_SLOT_REF2="ts650">
                <ANNOTATION_VALUE>number of persons registered are figures as at the second of February two thousand and seven</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a253" TIME_SLOT_REF1="ts651" TIME_SLOT_REF2="ts654">
                <ANNOTATION_VALUE>Professor Maurice Iwu told the ECOWAS fact finding mission</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a254" TIME_SLOT_REF1="ts655" TIME_SLOT_REF2="ts658">
                <ANNOTATION_VALUE>that a perfect election begins with a credible voters' register</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a255" TIME_SLOT_REF1="ts659" TIME_SLOT_REF2="ts660">
                <ANNOTATION_VALUE>while stressing that political parties cannot substitute candidates after thirteenth of February</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a256" TIME_SLOT_REF1="ts661" TIME_SLOT_REF2="ts664">
                <ANNOTATION_VALUE>for governorship elections</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a257" TIME_SLOT_REF1="ts665" TIME_SLOT_REF2="ts667">
                <ANNOTATION_VALUE>and twentieth of February for presidential elections</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a258" TIME_SLOT_REF1="ts669" TIME_SLOT_REF2="ts672">
                <ANNOTATION_VALUE>Professor Iwu says INEC has concluded preparations</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a259" TIME_SLOT_REF1="ts673" TIME_SLOT_REF2="ts675">
                <ANNOTATION_VALUE>for the elections</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a260" TIME_SLOT_REF1="ts677" TIME_SLOT_REF2="ts682">
                <ANNOTATION_VALUE>this include the acquisition of a central store for election materials</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a261" TIME_SLOT_REF1="ts683" TIME_SLOT_REF2="ts686">
                <ANNOTATION_VALUE>order for ballot papers and ballot boxes</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a262" TIME_SLOT_REF1="ts687" TIME_SLOT_REF2="ts694">
                <ANNOTATION_VALUE>he explained that actual tabulation of election results</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a263" TIME_SLOT_REF1="ts695" TIME_SLOT_REF2="ts696">

    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="default-lt" PARTICIPANT="f;?;Yoruba" TIER_ID="Transcription 3">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a223" TIME_SLOT_REF1="ts689" TIME_SLOT_REF2="ts690">
                <ANNOTATION_VALUE>over the years</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a224" TIME_SLOT_REF1="ts691" TIME_SLOT_REF2="ts694">
                <ANNOTATION_VALUE>the expected rest after long service to one's nation</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a225" TIME_SLOT_REF1="ts695" TIME_SLOT_REF2="ts696">
                <ANNOTATION_VALUE>is not the case of pensioners in Nigeria</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a226" TIME_SLOT_REF1="ts697" TIME_SLOT_REF2="ts698">
                <ANNOTATION_VALUE>this is because the retirement benefits</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a227" TIME_SLOT_REF1="ts699" TIME_SLOT_REF2="ts702">
                <ANNOTATION_VALUE>like gratuity and pension allowances</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a228" TIME_SLOT_REF1="ts703" TIME_SLOT_REF2="ts704">
                <ANNOTATION_VALUE>have become a problem</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a229" TIME_SLOT_REF1="ts705" TIME_SLOT_REF2="ts706">
                <ANNOTATION_VALUE>that has defied all solutions</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a230" TIME_SLOT_REF1="ts707" TIME_SLOT_REF2="ts713">
                <ANNOTATION_VALUE>backlog of pensioner arrears of those who were supposed to be enjoying</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a231" TIME_SLOT_REF1="ts715" TIME_SLOT_REF2="ts716">
                <ANNOTATION_VALUE>are not paid</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a232" TIME_SLOT_REF1="ts717" TIME_SLOT_REF2="ts718">
                <ANNOTATION_VALUE>while some have subsequently lost their lives</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a233" TIME_SLOT_REF1="ts719" TIME_SLOT_REF2="ts724">
                <ANNOTATION_VALUE>in order to overcome this</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a234" TIME_SLOT_REF1="ts725" TIME_SLOT_REF2="ts730">
                <ANNOTATION_VALUE>the pension reform act which establishes the contributory pension scheme</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a235" TIME_SLOT_REF1="ts731" TIME_SLOT_REF2="ts732">
                <ANNOTATION_VALUE>became a law</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a236" TIME_SLOT_REF1="ts733" TIME_SLOT_REF2="ts734">
                <ANNOTATION_VALUE>in June two thousand and four</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a237" TIME_SLOT_REF1="ts735" TIME_SLOT_REF2="ts738">
                <ANNOTATION_VALUE>the main objectives of the new contributory pension scheme are</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a238" TIME_SLOT_REF1="ts739" TIME_SLOT_REF2="ts742">
                <ANNOTATION_VALUE>to ensure that every person</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a239" TIME_SLOT_REF1="ts744" TIME_SLOT_REF2="ts746">
                <ANNOTATION_VALUE>who had worked either in public or private sector</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a240" TIME_SLOT_REF1="ts747" TIME_SLOT_REF2="ts748">
                <ANNOTATION_VALUE>receives his or her retirement benefit</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a241" TIME_SLOT_REF1="ts749" TIME_SLOT_REF2="ts750">
                <ANNOTATION_VALUE>as at when due</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a242" TIME_SLOT_REF1="ts751" TIME_SLOT_REF2="ts756">
                <ANNOTATION_VALUE>and assisting employees to save to cater</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a243" TIME_SLOT_REF1="ts757" TIME_SLOT_REF2="ts758">
                <ANNOTATION_VALUE>for their livelihood</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a244" TIME_SLOT_REF1="ts759" TIME_SLOT_REF2="ts763">
                <ANNOTATION_VALUE>during old age</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a245" TIME_SLOT_REF1="ts765" TIME_SLOT_REF2="ts767">
                <ANNOTATION_VALUE>also</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a246" TIME_SLOT_REF1="ts769" TIME_SLOT_REF2="ts772">
                <ANNOTATION_VALUE>it is established</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a247" TIME_SLOT_REF1="ts773" TIME_SLOT_REF2="ts776">
                <ANNOTATION_VALUE>to have a uniform set of rules and regulations</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a248" TIME_SLOT_REF1="ts777" TIME_SLOT_REF2="ts780">
                <ANNOTATION_VALUE>for the administration and payment of pension funds in Nigeria</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a249" TIME_SLOT_REF1="ts781" TIME_SLOT_REF2="ts784">
                <ANNOTATION_VALUE>pension funds are to be managed by pension fund administrators PFAs</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a250" TIME_SLOT_REF1="ts785" TIME_SLOT_REF2="ts786">
                <ANNOTATION_VALUE>licensed by the National Pension Commission</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a251" TIME_SLOT_REF1="ts787" TIME_SLOT_REF2="ts790">
                <ANNOTATION_VALUE>each employee is therefore mandated</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a252" TIME_SLOT_REF1="ts791" TIME_SLOT_REF2="ts793">
                <ANNOTATION_VALUE>to choose any pension fund the administrator</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a253" TIME_SLOT_REF1="ts795" TIME_SLOT_REF2="ts800">
                <ANNOTATION_VALUE>in order not to jeopardise the objectives of the new</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a254" TIME_SLOT_REF1="ts801" TIME_SLOT_REF2="ts802">
                <ANNOTATION_VALUE>pension scheme</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a255" TIME_SLOT_REF1="ts803" TIME_SLOT_REF2="ts806">
                <ANNOTATION_VALUE>there is the need to have deep knowledge about the various PFAs</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a256" TIME_SLOT_REF1="ts807" TIME_SLOT_REF2="ts808">
                <ANNOTATION_VALUE>it is against this background</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a257" TIME_SLOT_REF1="ts809" TIME_SLOT_REF2="ts814">
                <ANNOTATION_VALUE>that the University of Ibadan organised an interactive session</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a258" TIME_SLOT_REF1="ts815" TIME_SLOT_REF2="ts816">
                <ANNOTATION_VALUE>for its staff and the licensed PFAs</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a259" TIME_SLOT_REF1="ts817" TIME_SLOT_REF2="ts820">
                <ANNOTATION_VALUE>the staff commended the initiative of the UI management</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a260" TIME_SLOT_REF1="ts821" TIME_SLOT_REF2="ts822">
                <ANNOTATION_VALUE>the new scheme</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a261" TIME_SLOT_REF1="ts823" TIME_SLOT_REF2="ts827">
                <ANNOTATION_VALUE>mandates employers and employees</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a262" TIME_SLOT_REF1="ts829" TIME_SLOT_REF2="ts833">
                <ANNOTATION_VALUE>to contribute seven point five per cent each of employees' total monthly emoluments</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a263" TIME_SLOT_REF1="ts835" TIME_SLOT_REF2="ts836">
                <ANNOTATION_VALUE>Olaide Abass</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a264" TIME_SLOT_REF1="ts838" TIME_SLOT_REF2="ts840">
                <ANNOTATION_VALUE>NTA news</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>

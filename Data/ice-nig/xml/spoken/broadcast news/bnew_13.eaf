        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a257" TIME_SLOT_REF1="ts357" TIME_SLOT_REF2="ts358">
                <ANNOTATION_VALUE>to the meeting</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a270" TIME_SLOT_REF1="ts465" TIME_SLOT_REF2="ts471">
                <ANNOTATION_VALUE>a special prayer summit has been held for peaceful elections in Nigeria in April</ANNOTATION_VALUE>

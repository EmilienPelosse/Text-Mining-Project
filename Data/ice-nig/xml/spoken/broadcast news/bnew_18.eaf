        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a203" TIME_SLOT_REF1="ts695" TIME_SLOT_REF2="ts696">
                <ANNOTATION_VALUE>this men and women you see choose voluntarism as their watchword</ANNOTATION_VALUE>

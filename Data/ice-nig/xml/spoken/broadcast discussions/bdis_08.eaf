    <TIER ANNOTATOR="ug/lc/ts/ug DONE DONE DONE ug/ac DONE DONE" LINGUISTIC_TYPE_REF="default-lt" PARTICIPANT="m;?;Igbo" TIER_ID="Transcription 1">
        <ANNOTATION>

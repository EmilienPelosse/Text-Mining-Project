        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a84" TIME_SLOT_REF1="ts209" TIME_SLOT_REF2="ts217">
                <ANNOTATION_VALUE>unlike the frenzy atmosphere that characterised the commencement of the enumeration exercise</ANNOTATION_VALUE>

        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a134" TIME_SLOT_REF1="ts257" TIME_SLOT_REF2="ts259">
                <ANNOTATION_VALUE>which is central to the m-</ANNOTATION_VALUE>

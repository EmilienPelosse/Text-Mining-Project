        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a210" TIME_SLOT_REF1="ts719" TIME_SLOT_REF2="ts722">
                <ANNOTATION_VALUE>under the special marshal unit eighteen</ANNOTATION_VALUE>

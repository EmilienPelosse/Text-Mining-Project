        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a52" TIME_SLOT_REF1="ts129" TIME_SLOT_REF2="ts132">
                <ANNOTATION_VALUE>to agree on federal states' and local governments' contributions</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a53" TIME_SLOT_REF1="ts133" TIME_SLOT_REF2="ts134">
                <ANNOTATION_VALUE>after this meeting</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a54" TIME_SLOT_REF1="ts135" TIME_SLOT_REF2="ts138">
                <ANNOTATION_VALUE>Governor Ikedi Ohakim explained</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a55" TIME_SLOT_REF1="ts139" TIME_SLOT_REF2="ts143">
                <ANNOTATION_VALUE>in the light of the recent Imo state stakeholder's forum on social engineering</ANNOTATION_VALUE>

    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="default-lt" PARTICIPANT="m;?;Igbo" TIER_ID="Transcription 6">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a278" TIME_SLOT_REF1="ts827" TIME_SLOT_REF2="ts830">
                <ANNOTATION_VALUE>vision and its enabling law</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a279" TIME_SLOT_REF1="ts831" TIME_SLOT_REF2="ts832">
                <ANNOTATION_VALUE>to conduct any verification of the credentials</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a280" TIME_SLOT_REF1="ts833" TIME_SLOT_REF2="ts834">
                <ANNOTATION_VALUE>or papers</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a281" TIME_SLOT_REF1="ts835" TIME_SLOT_REF2="ts836">
                <ANNOTATION_VALUE>and on screening out or disqualifying Vice President Atiku Abubakar</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a282" TIME_SLOT_REF1="ts837" TIME_SLOT_REF2="ts840">
                <ANNOTATION_VALUE>or any other candidate for the two thousand and seven general elections</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a283" TIME_SLOT_REF1="ts841" TIME_SLOT_REF2="ts844">
                <ANNOTATION_VALUE>the plaintiffs therefore wants the court to declare that only the court</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a284" TIME_SLOT_REF1="ts846" TIME_SLOT_REF2="ts848">
                <ANNOTATION_VALUE>has the power to disqualify any candidate</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a285" TIME_SLOT_REF1="ts849" TIME_SLOT_REF2="ts850">
                <ANNOTATION_VALUE>sponsored by a political party</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a286" TIME_SLOT_REF1="ts851" TIME_SLOT_REF2="ts854">
                <ANNOTATION_VALUE>for contesting any election as provided</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a287" TIME_SLOT_REF1="ts855" TIME_SLOT_REF2="ts860">
                <ANNOTATION_VALUE>in the electoral act of two thousand and six</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a288" TIME_SLOT_REF1="ts861" TIME_SLOT_REF2="ts868">
                <ANNOTATION_VALUE>the court should therefore make an order setting aside all actions taken with regard</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a289" TIME_SLOT_REF1="ts869" TIME_SLOT_REF2="ts871">
                <ANNOTATION_VALUE>to the verification exercise</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a290" TIME_SLOT_REF1="ts873" TIME_SLOT_REF2="ts880">
                <ANNOTATION_VALUE>INEC has however filed a preliminary objection to the jurisdiction of the court</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a291" TIME_SLOT_REF1="ts881" TIME_SLOT_REF2="ts884">
                <ANNOTATION_VALUE>to entertain the suit</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a292" TIME_SLOT_REF1="ts885" TIME_SLOT_REF2="ts888">
                <ANNOTATION_VALUE>counsel to INEC Joe Gadzama</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a293" TIME_SLOT_REF1="ts889" TIME_SLOT_REF2="ts894">
                <ANNOTATION_VALUE>further asked for an order of the court dismissing or striking out the suit</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a294" TIME_SLOT_REF1="ts895" TIME_SLOT_REF2="ts896">
                <ANNOTATION_VALUE>for want of jurisdiction and lack of competence</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a295" TIME_SLOT_REF1="ts897" TIME_SLOT_REF2="ts901">
                <ANNOTATION_VALUE>he argued that the case does not disclose any reasonable course of action</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a296" TIME_SLOT_REF1="ts903" TIME_SLOT_REF2="ts904">
                <ANNOTATION_VALUE>and its premature speculative</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a297" TIME_SLOT_REF1="ts905" TIME_SLOT_REF2="ts908">
                <ANNOTATION_VALUE>and an abuse of court process</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a298" TIME_SLOT_REF1="ts909" TIME_SLOT_REF2="ts914">
                <ANNOTATION_VALUE>Justice Kwewumi  the presiding judge who gave his ruling on the preliminary objection this Friday</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a299" TIME_SLOT_REF1="ts915" TIME_SLOT_REF2="ts920">
                <ANNOTATION_VALUE>INEC concluded the verification of candidates of political parties two weeks ago</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a300" TIME_SLOT_REF1="ts921" TIME_SLOT_REF2="ts922">
                <ANNOTATION_VALUE>Vice President Atiku Abubakar one of the plaintiffs to the suit</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a301" TIME_SLOT_REF1="ts923" TIME_SLOT_REF2="ts924">
                <ANNOTATION_VALUE>submitted himself for verification</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a302" TIME_SLOT_REF1="ts925" TIME_SLOT_REF2="ts928">
                <ANNOTATION_VALUE>during the exercise</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a303" TIME_SLOT_REF1="ts929" TIME_SLOT_REF2="ts930">
                <ANNOTATION_VALUE>from Abuja</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a304" TIME_SLOT_REF1="ts931" TIME_SLOT_REF2="ts932">
                <ANNOTATION_VALUE>I am Kalu</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a305" TIME_SLOT_REF1="ts933" TIME_SLOT_REF2="ts934">
                <ANNOTATION_VALUE>Otisi</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>

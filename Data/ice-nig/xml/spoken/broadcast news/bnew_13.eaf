                <ANNOTATION_VALUE>and his wife Dame Patience to thank God for protection favour and provision</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a27" TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts44">
                <ANNOTATION_VALUE>throughout the hectic campaign rallies</ANNOTATION_VALUE>

        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a49" TIME_SLOT_REF1="ts119" TIME_SLOT_REF2="ts122">
                <ANNOTATION_VALUE>as agreed by the National Economic Council</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a50" TIME_SLOT_REF1="ts123" TIME_SLOT_REF2="ts124">
                <ANNOTATION_VALUE>on special funding for the Nigerian police</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>

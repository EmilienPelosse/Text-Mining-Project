        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a220" TIME_SLOT_REF1="ts617" TIME_SLOT_REF2="ts619">
                <ANNOTATION_VALUE>and these areas</ANNOTATION_VALUE>

        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a149" TIME_SLOT_REF1="ts289" TIME_SLOT_REF2="ts290">
                <ANNOTATION_VALUE>I have to give this background because</ANNOTATION_VALUE>

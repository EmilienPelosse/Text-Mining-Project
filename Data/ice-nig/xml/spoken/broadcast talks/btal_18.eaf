    <TIER ANNOTATOR="sf/ug/ts/ug DONE DONE DONE ag DONE" DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="default-lt" PARTICIPANT="?-?-?;AIT;m;?;Urhobo" TIER_ID="Transcription 1">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5" TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
                <ANNOTATION_VALUE>if you have</ANNOTATION_VALUE>

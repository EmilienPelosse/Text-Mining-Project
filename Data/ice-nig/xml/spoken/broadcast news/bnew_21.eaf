        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a215" TIME_SLOT_REF1="ts637" TIME_SLOT_REF2="ts639">
                <ANNOTATION_VALUE>Governor Ladoja noted that any philanthropic gesture towards providing good education</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a216" TIME_SLOT_REF1="ts641" TIME_SLOT_REF2="ts642">

        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a21" TIME_SLOT_REF1="ts67" TIME_SLOT_REF2="ts72">
                <ANNOTATION_VALUE>the American type of constitution that we are we we are practising here</ANNOTATION_VALUE>

        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a35" TIME_SLOT_REF1="ts105" TIME_SLOT_REF2="ts108">
                <ANNOTATION_VALUE>what do you think is going to happen</ANNOTATION_VALUE>

    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="default-lt" PARTICIPANT="m;?;Yoruba" TIER_ID="Transcription 6">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a222" TIME_SLOT_REF1="ts613" TIME_SLOT_REF2="ts618">
                <ANNOTATION_VALUE>when first sighted among crowd of aggrieved students that surrounded helpless Abdul Akeem Mustafa</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a223" TIME_SLOT_REF1="ts619" TIME_SLOT_REF2="ts620">
                <ANNOTATION_VALUE>he could mistakenly have been taken for a thief</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a224" TIME_SLOT_REF1="ts621" TIME_SLOT_REF2="ts622">
                <ANNOTATION_VALUE>but on a closer look one would know that the man believed</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a225" TIME_SLOT_REF1="ts623" TIME_SLOT_REF2="ts624">
                <ANNOTATION_VALUE>to be in his thirties</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a226" TIME_SLOT_REF1="ts625" TIME_SLOT_REF2="ts626">
                <ANNOTATION_VALUE>is just a victim of circumstances</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a227" TIME_SLOT_REF1="ts627" TIME_SLOT_REF2="ts634">
                <ANNOTATION_VALUE>Abdul Akeem Mustafa an indigene of Oshogbo Osun state explained to NTA news in Yoruba</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a228" TIME_SLOT_REF1="ts635" TIME_SLOT_REF2="ts638">
                <ANNOTATION_VALUE>that he is a mobile Islamic book seller</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a229" TIME_SLOT_REF1="ts639" TIME_SLOT_REF2="ts640">
                <ANNOTATION_VALUE>and he has just bought material from a centre</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a230" TIME_SLOT_REF1="ts641" TIME_SLOT_REF2="ts644">
                <ANNOTATION_VALUE>here in Ibadan</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a231" TIME_SLOT_REF1="ts645" TIME_SLOT_REF2="ts648">
                <ANNOTATION_VALUE>he added that he was coming from a restaurant</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a232" TIME_SLOT_REF1="ts649" TIME_SLOT_REF2="ts654">
                <ANNOTATION_VALUE>when a student suddenly rough-handled him</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a233" TIME_SLOT_REF1="ts656" TIME_SLOT_REF2="ts659">
                <ANNOTATION_VALUE>alleging him of taking his genital organ</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a234" TIME_SLOT_REF1="ts661" TIME_SLOT_REF2="ts663">
                <ANNOTATION_VALUE>which he said was untrue</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a235" TIME_SLOT_REF1="ts665" TIME_SLOT_REF2="ts670">
                <ANNOTATION_VALUE>the man who could not explain himself properly for the fear of being lynched</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a236" TIME_SLOT_REF1="ts671" TIME_SLOT_REF2="ts676">
                <ANNOTATION_VALUE>by the aggrieved onlookers</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a237" TIME_SLOT_REF1="ts677" TIME_SLOT_REF2="ts679">
                <ANNOTATION_VALUE>was only swearing and claimed innocence</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a238" TIME_SLOT_REF1="ts681" TIME_SLOT_REF2="ts683">
                <ANNOTATION_VALUE>of the incident</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a239" TIME_SLOT_REF1="ts686" TIME_SLOT_REF2="ts690">
                <ANNOTATION_VALUE>however to Ayola Ayobami a student of the Christ Apostolic Church Grammar School Oniere Oritaperin Ibadan</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a240" TIME_SLOT_REF1="ts691" TIME_SLOT_REF2="ts696">
                <ANNOTATION_VALUE>who claimed that his genital organ had been taken</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a241" TIME_SLOT_REF1="ts697" TIME_SLOT_REF2="ts700">
                <ANNOTATION_VALUE>all the defence of Abdul Akeem fell on deaf head</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a242" TIME_SLOT_REF1="ts701" TIME_SLOT_REF2="ts702">
                <ANNOTATION_VALUE>although he was taken to a corner where some people checked</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a243" TIME_SLOT_REF1="ts703" TIME_SLOT_REF2="ts704">
                <ANNOTATION_VALUE>his private part and cross-examined him</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a244" TIME_SLOT_REF1="ts705" TIME_SLOT_REF2="ts706">
                <ANNOTATION_VALUE>yet he was not satisfied</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a245" TIME_SLOT_REF1="ts707" TIME_SLOT_REF2="ts708">
                <ANNOTATION_VALUE>but requested to be given a chance</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a246" TIME_SLOT_REF1="ts709" TIME_SLOT_REF2="ts710">
                <ANNOTATION_VALUE>to test his</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a247" TIME_SLOT_REF1="ts711" TIME_SLOT_REF2="ts713">
                <ANNOTATION_VALUE>genital organ</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a248" TIME_SLOT_REF1="ts715" TIME_SLOT_REF2="ts719">
                <ANNOTATION_VALUE>as of the filing of this report elders in the area</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a249" TIME_SLOT_REF1="ts721" TIME_SLOT_REF2="ts722">
                <ANNOTATION_VALUE>were still battling with</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a250" TIME_SLOT_REF1="ts723" TIME_SLOT_REF2="ts728">
                <ANNOTATION_VALUE>how to obtain more facts</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a251" TIME_SLOT_REF1="ts729" TIME_SLOT_REF2="ts731">
                <ANNOTATION_VALUE>on the issue</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a252" TIME_SLOT_REF1="ts734" TIME_SLOT_REF2="ts741">
                <ANNOTATION_VALUE>however some residents are now appealing to the law enforcement agents</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a253" TIME_SLOT_REF1="ts743" TIME_SLOT_REF2="ts754">
                <ANNOTATION_VALUE>to be always at alert in order to ensure that innocent blood</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a254" TIME_SLOT_REF1="ts755" TIME_SLOT_REF2="ts756">
                <ANNOTATION_VALUE>are prevented from being shed</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a255" TIME_SLOT_REF1="ts757" TIME_SLOT_REF2="ts758">
                <ANNOTATION_VALUE>Abiodun Oladepo</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a256" TIME_SLOT_REF1="ts759" TIME_SLOT_REF2="ts762">
                <ANNOTATION_VALUE>NTA news</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>

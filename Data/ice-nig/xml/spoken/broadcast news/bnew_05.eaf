        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a85" TIME_SLOT_REF1="ts219" TIME_SLOT_REF2="ts224">
                <ANNOTATION_VALUE>the office of the national population commission was quiet as most officials were deployed d-</ANNOTATION_VALUE>

        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a707" TIME_SLOT_REF1="ts1393" TIME_SLOT_REF2="ts1394">
                <ANNOTATION_VALUE>you know I told you the other time </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a708" TIME_SLOT_REF1="ts1395" TIME_SLOT_REF2="ts1396">
                <ANNOTATION_VALUE>when- whenever you're with any henna artist and you're washing off you henna </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a709" TIME_SLOT_REF1="ts1397" TIME_SLOT_REF2="ts1398">
                <ANNOTATION_VALUE>don't be alarmed it will definitely come out nicely </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a710" TIME_SLOT_REF1="ts1399" TIME_SLOT_REF2="ts1400">
                <ANNOTATION_VALUE>so I have a proof here </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a711" TIME_SLOT_REF1="ts1401" TIME_SLOT_REF2="ts1402">
                <ANNOTATION_VALUE>as you can see our henna it's out and beautiful </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a712" TIME_SLOT_REF1="ts1403" TIME_SLOT_REF2="ts1404">
                <ANNOTATION_VALUE>so now we just have to do the finishing </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a713" TIME_SLOT_REF1="ts1405" TIME_SLOT_REF2="ts1406">
                <ANNOTATION_VALUE>and the only thing I think we need </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a714" TIME_SLOT_REF1="ts1407" TIME_SLOT_REF2="ts1408">
                <ANNOTATION_VALUE>as you can see it's washed so don't feel my henna is still there  this is  her skin </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a715" TIME_SLOT_REF1="ts1409" TIME_SLOT_REF2="ts1410">
                <ANNOTATION_VALUE>is her skin </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a716" TIME_SLOT_REF1="ts1411" TIME_SLOT_REF2="ts1412">
                <ANNOTATION_VALUE>so </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a717" TIME_SLOT_REF1="ts1413" TIME_SLOT_REF2="ts1414">
                <ANNOTATION_VALUE>what w-</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a718" TIME_SLOT_REF1="ts1415" TIME_SLOT_REF2="ts1416">
                <ANNOTATION_VALUE>we need to do now is the finishing </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a719" TIME_SLOT_REF1="ts1417" TIME_SLOT_REF2="ts1418">
                <ANNOTATION_VALUE>and erm all we need </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a720" TIME_SLOT_REF1="ts1419" TIME_SLOT_REF2="ts1420">
                <ANNOTATION_VALUE>is the henna oil</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a721" TIME_SLOT_REF1="ts1421" TIME_SLOT_REF2="ts1422">
                <ANNOTATION_VALUE>I just put a  bit of that </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a722" TIME_SLOT_REF1="ts1423" TIME_SLOT_REF2="ts1424">
                <ANNOTATION_VALUE>yeah </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a723" TIME_SLOT_REF1="ts1425" TIME_SLOT_REF2="ts1426">
                <ANNOTATION_VALUE>then I'll massage </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a724" TIME_SLOT_REF1="ts1427" TIME_SLOT_REF2="ts1428">
                <ANNOTATION_VALUE>so the henna oil goes into her skin </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a725" TIME_SLOT_REF1="ts1429" TIME_SLOT_REF2="ts1430">
                <ANNOTATION_VALUE>and it enhances her henna to look nicer </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a726" TIME_SLOT_REF1="ts1431" TIME_SLOT_REF2="ts1432">
                <ANNOTATION_VALUE>and shiny </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a727" TIME_SLOT_REF1="ts1433" TIME_SLOT_REF2="ts1434">
                <ANNOTATION_VALUE>so </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a728" TIME_SLOT_REF1="ts1435" TIME_SLOT_REF2="ts1436">
                <ANNOTATION_VALUE>that's what the henna oil does anyway</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a729" TIME_SLOT_REF1="ts1437" TIME_SLOT_REF2="ts1438">
                <ANNOTATION_VALUE>that's it </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a730" TIME_SLOT_REF1="ts1439" TIME_SLOT_REF2="ts1440">
                <ANNOTATION_VALUE>let me put the spray </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a743" TIME_SLOT_REF1="ts1441" TIME_SLOT_REF2="ts1442">
                <ANNOTATION_VALUE>her henna spray too is part of the finishing </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a744" TIME_SLOT_REF1="ts1443" TIME_SLOT_REF2="ts1444">
                <ANNOTATION_VALUE>and that's all you need to finish your henna </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a745" TIME_SLOT_REF1="ts1445" TIME_SLOT_REF2="ts1446">
                <ANNOTATION_VALUE>you can do this all by yourself </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a746" TIME_SLOT_REF1="ts1447" TIME_SLOT_REF2="ts1448">
                <ANNOTATION_VALUE>I don't know </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a747" TIME_SLOT_REF1="ts1449" TIME_SLOT_REF2="ts1450">
                <ANNOTATION_VALUE>okay </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a748" TIME_SLOT_REF1="ts1451" TIME_SLOT_REF2="ts1452">
                <ANNOTATION_VALUE>I don't know why anyone won't be able to do this </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a749" TIME_SLOT_REF1="ts1453" TIME_SLOT_REF2="ts1454">
                <ANNOTATION_VALUE>because it's so simple </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a750" TIME_SLOT_REF1="ts1455" TIME_SLOT_REF2="ts1456">
                <ANNOTATION_VALUE>here we have it done so nice </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a751" TIME_SLOT_REF1="ts1457" TIME_SLOT_REF2="ts1458">
                <ANNOTATION_VALUE>and beautiful</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a752" TIME_SLOT_REF1="ts1459" TIME_SLOT_REF2="ts1460">
                <ANNOTATION_VALUE>so her henna is ready </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a753" TIME_SLOT_REF1="ts1461" TIME_SLOT_REF2="ts1462">
                <ANNOTATION_VALUE>you're ready to go</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a754" TIME_SLOT_REF1="ts1463" TIME_SLOT_REF2="ts1464">
                <ANNOTATION_VALUE>well </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a755" TIME_SLOT_REF1="ts1465" TIME_SLOT_REF2="ts1466">
                <ANNOTATION_VALUE>that's all about erm drawing henna on your hands and all of that </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a756" TIME_SLOT_REF1="ts1467" TIME_SLOT_REF2="ts1468">
                <ANNOTATION_VALUE>I think the only thing we need to learn now is to accessorise our henna</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a757" TIME_SLOT_REF1="ts1469" TIME_SLOT_REF2="ts1470">
                <ANNOTATION_VALUE>so I think we'll be doing that next week so keep a date with me I'll be here next week to accessorise your henna</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a758" TIME_SLOT_REF1="ts1471" TIME_SLOT_REF2="ts1472">
                <ANNOTATION_VALUE>see you </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>

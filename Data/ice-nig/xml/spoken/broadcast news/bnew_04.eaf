            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a204" TIME_SLOT_REF1="ts551" TIME_SLOT_REF2="ts555">
                <ANNOTATION_VALUE>are yet to have a feel of the counting exercise</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a205" TIME_SLOT_REF1="ts557" TIME_SLOT_REF2="ts560">
                <ANNOTATION_VALUE>these horde of complaints</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a206" TIME_SLOT_REF1="ts561" TIME_SLOT_REF2="ts566">
                <ANNOTATION_VALUE>took us to Orita Challenge local office of the NPC in search of the coordinator</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a207" TIME_SLOT_REF1="ts567" TIME_SLOT_REF2="ts568">
                <ANNOTATION_VALUE>Kunle Ojoge</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a208" TIME_SLOT_REF1="ts569" TIME_SLOT_REF2="ts572">
                <ANNOTATION_VALUE>but alas what did we find</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a209" TIME_SLOT_REF1="ts573" TIME_SLOT_REF2="ts574">
                <ANNOTATION_VALUE>we met </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a210" TIME_SLOT_REF1="ts575" TIME_SLOT_REF2="ts577">
                <ANNOTATION_VALUE>what we met was alarming</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a211" TIME_SLOT_REF1="ts579" TIME_SLOT_REF2="ts582">
                <ANNOTATION_VALUE>as we saw group of enumerators dancing to a gospel music</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a212" TIME_SLOT_REF1="ts583" TIME_SLOT_REF2="ts584">
                <ANNOTATION_VALUE>in protest</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a213" TIME_SLOT_REF1="ts585" TIME_SLOT_REF2="ts588">
                <ANNOTATION_VALUE>while NTA crew was not spared</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a214" TIME_SLOT_REF1="ts589" TIME_SLOT_REF2="ts591">
                <ANNOTATION_VALUE>their anger</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a215" TIME_SLOT_REF1="ts593" TIME_SLOT_REF2="ts599">
                <ANNOTATION_VALUE>on the general overview of the headcount exercise</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a216" TIME_SLOT_REF1="ts601" TIME_SLOT_REF2="ts604">
                <ANNOTATION_VALUE>honourable Babs Oduyoye</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a217" TIME_SLOT_REF1="ts605" TIME_SLOT_REF2="ts608">
                <ANNOTATION_VALUE>is a member of the federal house of representatives</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a218" TIME_SLOT_REF1="ts609" TIME_SLOT_REF2="ts613">
                <ANNOTATION_VALUE>it is expected that with the extension</ANNOTATION_VALUE>

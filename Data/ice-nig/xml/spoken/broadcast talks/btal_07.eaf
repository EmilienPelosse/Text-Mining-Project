            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a93" TIME_SLOT_REF1="ts319" TIME_SLOT_REF2="ts320">
                <ANNOTATION_VALUE>we've got to go man</ANNOTATION_VALUE>

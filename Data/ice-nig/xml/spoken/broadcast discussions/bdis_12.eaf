        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a29" TIME_SLOT_REF1="ts87" TIME_SLOT_REF2="ts90">
                <ANNOTATION_VALUE>we have problems with the primaries</ANNOTATION_VALUE>

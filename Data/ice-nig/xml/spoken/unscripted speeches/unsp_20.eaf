        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a65" TIME_SLOT_REF1="ts189" TIME_SLOT_REF2="ts195">
                <ANNOTATION_VALUE>than saying addition and subtraction in English and speaking your language don't you understand</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a43" TIME_SLOT_REF1="ts197" TIME_SLOT_REF2="ts198">

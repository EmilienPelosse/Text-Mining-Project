        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a14" TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts126">
                <ANNOTATION_VALUE>in areas not yet enumerated</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a15" TIME_SLOT_REF1="ts127" TIME_SLOT_REF2="ts130">
                <ANNOTATION_VALUE>correspondent Olaide Abass has details</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a46" TIME_SLOT_REF1="ts197" TIME_SLOT_REF2="ts200">
                <ANNOTATION_VALUE>the national census in Ibarapa zone has been a huge success</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a47" TIME_SLOT_REF1="ts201" TIME_SLOT_REF2="ts206">
                <ANNOTATION_VALUE>in spite of initial setback arising from land</ANNOTATION_VALUE>

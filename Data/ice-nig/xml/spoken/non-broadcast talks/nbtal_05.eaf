        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a269" TIME_SLOT_REF1="ts531" TIME_SLOT_REF2="ts532">
                <ANNOTATION_VALUE>I have just started a tradition</ANNOTATION_VALUE>

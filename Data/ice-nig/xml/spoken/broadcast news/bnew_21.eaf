        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a213" TIME_SLOT_REF1="ts627" TIME_SLOT_REF2="ts630">
                <ANNOTATION_VALUE>while reiterating his administration's belief that</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a214" TIME_SLOT_REF1="ts631" TIME_SLOT_REF2="ts635">
                <ANNOTATION_VALUE>government alone cannot fund education</ANNOTATION_VALUE>

        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a47" TIME_SLOT_REF1="ts113" TIME_SLOT_REF2="ts114">
                <ANNOTATION_VALUE>Vice President Jonathan has met severally with these state governors</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a48" TIME_SLOT_REF1="ts115" TIME_SLOT_REF2="ts118">
                <ANNOTATION_VALUE>the Police Minister and Police High Command</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>

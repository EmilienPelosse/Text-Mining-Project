            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a249" TIME_SLOT_REF1="ts319" TIME_SLOT_REF2="ts324">
                <ANNOTATION_VALUE>in another news President Goodluck Jonathan has applauded the Muslim Omar</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a250" TIME_SLOT_REF1="ts325" TIME_SLOT_REF2="ts326">
                <ANNOTATION_VALUE>for their continued prayers and counselling</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a251" TIME_SLOT_REF1="ts327" TIME_SLOT_REF2="ts330">
                <ANNOTATION_VALUE>of their followers towards achieving peace and stability</ANNOTATION_VALUE>

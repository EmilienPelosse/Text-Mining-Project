        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a271" TIME_SLOT_REF1="ts473" TIME_SLOT_REF2="ts480">
                <ANNOTATION_VALUE>the prayer organised by NAFSAT in Lagos was attended by the minister of state for agriculture</ANNOTATION_VALUE>

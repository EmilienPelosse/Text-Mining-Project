                <ANNOTATION_VALUE>we ended up in the second world war</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a361" TIME_SLOT_REF1="ts1161" TIME_SLOT_REF2="ts1162">
                <ANNOTATION_VALUE>yes</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a362" TIME_SLOT_REF1="ts1163" TIME_SLOT_REF2="ts1172">
                <ANNOTATION_VALUE>you can actually use that competitive revaluation to attack economies that you do not like</ANNOTATION_VALUE>

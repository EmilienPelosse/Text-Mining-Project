        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a358" TIME_SLOT_REF1="ts1153" TIME_SLOT_REF2="ts1154">
                <ANNOTATION_VALUE>yeah because the last time we'll had</ANNOTATION_VALUE>

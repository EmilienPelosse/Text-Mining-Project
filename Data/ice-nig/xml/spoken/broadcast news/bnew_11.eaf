            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a698" TIME_SLOT_REF1="ts887" TIME_SLOT_REF2="ts888">
                <ANNOTATION_VALUE>was in the field</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a699" TIME_SLOT_REF1="ts889" TIME_SLOT_REF2="ts890">
                <ANNOTATION_VALUE>monitoring</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a700" TIME_SLOT_REF1="ts891" TIME_SLOT_REF2="ts893">
                <ANNOTATION_VALUE>activities</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a701" TIME_SLOT_REF1="ts895" TIME_SLOT_REF2="ts898">
                <ANNOTATION_VALUE>at Akingbade area Egbeda local government</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a702" TIME_SLOT_REF1="ts899" TIME_SLOT_REF2="ts902">
                <ANNOTATION_VALUE>enumerators were at work but residents still complained</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a704" TIME_SLOT_REF1="ts903" TIME_SLOT_REF2="ts904">
                <ANNOTATION_VALUE>of not having been counted</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a705" TIME_SLOT_REF1="ts905" TIME_SLOT_REF2="ts908">
                <ANNOTATION_VALUE>two young supposedly enumerators</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a706" TIME_SLOT_REF1="ts909" TIME_SLOT_REF2="ts914">
                <ANNOTATION_VALUE>who professed to have had their training</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a707" TIME_SLOT_REF1="ts915" TIME_SLOT_REF2="ts916">
                <ANNOTATION_VALUE>were caught</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a708" TIME_SLOT_REF1="ts917" TIME_SLOT_REF2="ts920">
                <ANNOTATION_VALUE>as they could not show any identity card</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a709" TIME_SLOT_REF1="ts921" TIME_SLOT_REF2="ts924">
                <ANNOTATION_VALUE>neither were they with official census materials</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a710" TIME_SLOT_REF1="ts925" TIME_SLOT_REF2="ts928">
                <ANNOTATION_VALUE>at Olaogun Old Ife Road</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a711" TIME_SLOT_REF1="ts929" TIME_SLOT_REF2="ts930">
                <ANNOTATION_VALUE>the situation was better</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a712" TIME_SLOT_REF1="ts931" TIME_SLOT_REF2="ts934">
                <ANNOTATION_VALUE>but enumerators still complain of materials shortage</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a713" TIME_SLOT_REF1="ts935" TIME_SLOT_REF2="ts936">
                <ANNOTATION_VALUE>for the census boss</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a714" TIME_SLOT_REF1="ts937" TIME_SLOT_REF2="ts938">
                <ANNOTATION_VALUE>there is still time left for those yet to be c-</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a715" TIME_SLOT_REF1="ts939" TIME_SLOT_REF2="ts941">
                <ANNOTATION_VALUE>enumerated</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>

        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a94" TIME_SLOT_REF1="ts331" TIME_SLOT_REF2="ts334">
                <ANNOTATION_VALUE>he accused of being a witch</ANNOTATION_VALUE>

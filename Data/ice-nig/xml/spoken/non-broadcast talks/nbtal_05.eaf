        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a266" TIME_SLOT_REF1="ts525" TIME_SLOT_REF2="ts526">
                <ANNOTATION_VALUE>I do not have to force the Urhobo student in my department</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a267" TIME_SLOT_REF1="ts527" TIME_SLOT_REF2="ts528">

        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a30" TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts54">
                <ANNOTATION_VALUE>which captured the essence of the event</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a31" TIME_SLOT_REF1="ts55" TIME_SLOT_REF2="ts58">
                <ANNOTATION_VALUE>President Jonathan while thanking Nigerians for praying for him in both churches mosques and homes</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>

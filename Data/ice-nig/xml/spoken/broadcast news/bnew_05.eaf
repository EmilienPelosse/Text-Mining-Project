        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a87" TIME_SLOT_REF1="ts227" TIME_SLOT_REF2="ts232">
                <ANNOTATION_VALUE>to complement the efforts of enumerators</ANNOTATION_VALUE>

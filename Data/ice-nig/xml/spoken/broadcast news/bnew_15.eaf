        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a95" TIME_SLOT_REF1="ts335" TIME_SLOT_REF2="ts336">
                <ANNOTATION_VALUE>and was responsible for his setback</ANNOTATION_VALUE>

        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a35" TIME_SLOT_REF1="ts87" TIME_SLOT_REF2="ts90">
                <ANNOTATION_VALUE>so we are going to explore all of this processes</ANNOTATION_VALUE>

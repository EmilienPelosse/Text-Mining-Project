        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a357" TIME_SLOT_REF1="ts1151" TIME_SLOT_REF2="ts1152">
                <ANNOTATION_VALUE>fellowship in a living church</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a358" TIME_SLOT_REF1="ts1153" TIME_SLOT_REF2="ts1156">
                <ANNOTATION_VALUE>move away from your sinful friends</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a359" TIME_SLOT_REF1="ts1157" TIME_SLOT_REF2="ts1162">
                <ANNOTATION_VALUE>be involved in Evangelism by preaching the gospel</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a360" TIME_SLOT_REF1="ts1163" TIME_SLOT_REF2="ts1166">
                <ANNOTATION_VALUE>and by your behaviour</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a361" TIME_SLOT_REF1="ts1167" TIME_SLOT_REF2="ts1169">
                <ANNOTATION_VALUE>show love to others</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a362" TIME_SLOT_REF1="ts1171" TIME_SLOT_REF2="ts1172">
                <ANNOTATION_VALUE>care for the needy</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a363" TIME_SLOT_REF1="ts1173" TIME_SLOT_REF2="ts1176">
                <ANNOTATION_VALUE>and under pr- privileged</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a364" TIME_SLOT_REF1="ts1177" TIME_SLOT_REF2="ts1178">
                <ANNOTATION_VALUE>by sharing your goodies with them</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a365" TIME_SLOT_REF1="ts1179" TIME_SLOT_REF2="ts1182">
                <ANNOTATION_VALUE>you are invited to our monthly prayer summit</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a366" TIME_SLOT_REF1="ts1183" TIME_SLOT_REF2="ts1186">
                <ANNOTATION_VALUE>every second Saturday of the month</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a367" TIME_SLOT_REF1="ts1187" TIME_SLOT_REF2="ts1188">
                <ANNOTATION_VALUE>may God bless you as you come</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a368" TIME_SLOT_REF1="ts1189" TIME_SLOT_REF2="ts1191">
                <ANNOTATION_VALUE>the venue is LOHEM office</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a369" TIME_SLOT_REF1="ts1193" TIME_SLOT_REF2="ts1194">
                <ANNOTATION_VALUE>now located at number one Ogunbiyi lane</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a370" TIME_SLOT_REF1="ts1195" TIME_SLOT_REF2="ts1196">
                <ANNOTATION_VALUE>Ogui Enugu</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a371" TIME_SLOT_REF1="ts1198" TIME_SLOT_REF2="ts1200">
                <ANNOTATION_VALUE>behind Fidelity Bank off Ogui road</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
